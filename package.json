{
  "name": "moodflare",
  "version": "1.0.0",
  "description": "A mood tracking web app with dark orange aesthetic",
  "scripts": {
    "start": "npx serve . -p 3000",
    "dev":   "npx serve . -p 3000 --no-clipboard",
    "build": "node scripts/build.js",
    "android": "npm run build && npx cap sync android && npx cap open android"
  },
  "keywords": ["mood", "tracker", "wellbeing"],
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  }
}
